# 若 ONLYOFFICE 与应用不在同一网络，请配置为可被 ONLYOFFICE 访问的绝对地址（示例：https://app.example.com/api）
WINLOOP_API_BASE_URL=/api

WINLOOP_AI_PROVIDER=openai-compatible
WINLOOP_AI_BASE_URL=https://api.openai.com/v1
WINLOOP_AI_API_KEY=
WINLOOP_AI_MODEL=gpt-4o-mini
WINLOOP_AI_MODEL_CATALOG_JSON=
WINLOOP_AI_MODEL_PRICING_JSON=
WINLOOP_AI_TEMPERATURE=0.2
WINLOOP_AI_TOP_P=1
WINLOOP_AI_MAX_TOKENS=0
WINLOOP_AI_PRESENCE_PENALTY=0
WINLOOP_AI_FREQUENCY_PENALTY=0
WINLOOP_AI_TIMEOUT_MS=15000
WINLOOP_AI_MAX_RETRIES=2
WINLOOP_DOC_AI_PROVIDER=openai-compatible
WINLOOP_DOC_AI_BASE_URL=https://api.openai.com/v1
WINLOOP_DOC_AI_API_KEY=
WINLOOP_DOC_AI_MODEL=gpt-4o-mini
WINLOOP_DOC_AI_MODEL_PRICING_JSON=
WINLOOP_DOC_AI_TIMEOUT_MS=15000
WINLOOP_DOC_AI_MAX_RETRIES=2
WINLOOP_ONLYOFFICE_ENDPOINT=
WINLOOP_ONLYOFFICE_JWT_SECRET=
# 应用外网基地址（推荐，必须为可访问应用的绝对地址，不带 /api；例如 https://app.example.com）
WINLOOP_PUBLIC_BASE_URL=
# 项目资源临时访问地址有效期（秒）
WINLOOP_PROJECT_RESOURCE_ACCESS_URL_TTL_SECONDS=600
WINLOOP_ADMIN_AI_ENABLED=false
WINLOOP_TAVILY_API_KEY=
WINLOOP_ADMIN_AI_WEB_TIMEOUT_MS=12000
WINLOOP_ADMIN_AI_MAX_WEB_RESULTS=5
WINLOOP_ADMIN_AI_MAX_PAGE_CHARS=10000

WINLOOP_PG_URL=postgresql://winloop:password@127.0.0.1:5432/winloop

WINLOOP_REDIS_URL=redis://:password@127.0.0.1:6379/0
WINLOOP_CONTEST_AUTO_SEED=false
WINLOOP_RESOURCE_RECYCLE_WORKER_ENABLED=true
WINLOOP_RESOURCE_RECYCLE_WORKER_INTERVAL_MS=1800000
WINLOOP_RESOURCE_RECYCLE_RETENTION_DAYS=30
WINLOOP_RESOURCE_RECYCLE_WORKER_BATCH_SIZE=200

WINLOOP_STORAGE_PROVIDER=local
WINLOOP_STORAGE_LOCAL_ROOT=./tmp/document-storage
WINLOOP_STORAGE_ENDPOINT=
WINLOOP_STORAGE_REGION=
WINLOOP_STORAGE_BUCKET=
WINLOOP_STORAGE_ACCESS_KEY=
WINLOOP_STORAGE_SECRET_KEY=
WINLOOP_STORAGE_FORCE_PATH_STYLE=true
