WINLOOP_PG_URL=postgresql://winloop:password@127.0.0.1:5432/winloop_staging
WINLOOP_REDIS_URL=redis://:password@127.0.0.1:6379/1
WINLOOP_STORAGE_PROVIDER=local
WINLOOP_STORAGE_LOCAL_ROOT=/app/tmp/document-storage
WINLOOP_CONFIG_MASTER_KEY=
WINLOOP_PUBLIC_BASE_URL=https://staging.example.com
WINLOOP_API_BASE_URL=/api
WINLOOP_ONLYOFFICE_ENDPOINT=
WINLOOP_ONLYOFFICE_JWT_SECRET=
WINLOOP_PROJECT_RESOURCE_ACCESS_URL_TTL_SECONDS=600
WINLOOP_CONTEST_AUTO_SEED=false
WINLOOP_MEETING_RTC_PROVIDER=livekit
WINLOOP_MEETING_RTC_SERVER_URL=http://staging.example.com:7880
WINLOOP_MEETING_RTC_API_KEY=
WINLOOP_MEETING_RTC_API_SECRET=
WINLOOP_MEETING_RTC_ROOM_PREFIX=staging-winloop
WINLOOP_MEETING_ASR_PROVIDER=openai-compatible
WINLOOP_MEETING_WORKER_ENABLED=true
WINLOOP_MEETING_MONITORING_PROMETHEUS_BASE_URL=http://meeting-prometheus:9090
WINLOOP_SENTRY_DSN=
WINLOOP_SENTRY_ENVIRONMENT=staging
WINLOOP_SENTRY_TRACES_SAMPLE_RATE=0.1
WINLOOP_SENTRY_RELEASE=
