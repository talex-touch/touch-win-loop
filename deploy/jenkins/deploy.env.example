COMPOSE_PROJECT_NAME=touch-win-loop-staging
SERVICE_NAME=winloop
DOCKER_EXTERNAL_NETWORK=1panel-network
RUNTIME_ENV_FILE=.env.runtime
HEALTHCHECK_URL=http://127.0.0.1:3511/api/health
HEALTHCHECK_ATTEMPTS=20
HEALTHCHECK_INTERVAL_SEC=3
ROLLBACK_ON_FAILURE=true
FORCE_RECREATE=true
APP_BIND_IP=127.0.0.1
APP_HOST_PORT=3511
STORAGE_HOST_DIR=./storage
DB_MIGRATION_DIR=
DB_MIGRATION_FILES=
DB_MIGRATION_CLIENT_IMAGE=postgres:18-alpine
DB_MIGRATION_NETWORK=1panel-network
MEETING_STACK_ENABLED=true
MEETING_EGRESS_ENABLED=false
MEETING_REDIS_IMAGE=redis:7-alpine
MEETING_LIVEKIT_IMAGE=livekit/livekit-server:latest
MEETING_LIVEKIT_EGRESS_IMAGE=livekit/egress:latest
MEETING_PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
MEETING_NODE_EXPORTER_IMAGE=prom/node-exporter:v1.8.2
MEETING_CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2
MEETING_DATA_HOST_DIR=./meeting-data
MEETING_EGRESS_OUTPUT_HOST_DIR=./meeting-data/egress
MEETING_LIVEKIT_CONFIG_FILE=./livekit.yaml
MEETING_EGRESS_CONFIG_FILE=./egress.yaml
MEETING_PROMETHEUS_CONFIG_FILE=./prometheus.yml
MEETING_LIVEKIT_HTTP_PORT=7880
MEETING_LIVEKIT_TCP_PORT=7881
MEETING_LIVEKIT_RTC_UDP_RANGE=50000-50100
MEETING_LIVEKIT_USE_EXTERNAL_IP=true
MEETING_LIVEKIT_WEBHOOK_URL=http://winloop:3000/api/internal/meetings/provider-events
MEETING_PROMETHEUS_HOST_PORT=9091
MEETING_PROMETHEUS_RETENTION=7d
