# Compose target
WINLOOP_PROJECT_DIR=/opt/1panel/apps/touch-win-loop
WINLOOP_COMPOSE_FILE=docker-compose.yml
WINLOOP_SERVICE_NAME=winloop

# Deploy image selector
WINLOOP_IMAGE_REPO=ghcr.io/your-org/touch-win-loop
WINLOOP_IMAGE_TAG=latest

# Runtime env file loading order (later overrides earlier)
WINLOOP_RUNTIME_ENV_FILES=.env,.env.dev,.env.prod,.env.local,.env.server
WINLOOP_FORCE_RECREATE=true

# Runtime required env (minimal set)
WINLOOP_PG_URL=postgresql://winloop:password@127.0.0.1:5432/winloop
WINLOOP_REDIS_URL=redis://:password@127.0.0.1:6379/0
WINLOOP_CONFIG_MASTER_KEY=

# Runtime optional env（可在 UI 覆盖，Env 作为兜底）
WINLOOP_API_BASE_URL=/api
WINLOOP_CONTEST_AUTO_SEED=false
WINLOOP_BUILD_VERSION=
WINLOOP_BUILD_COMMIT_SHA=
WINLOOP_DB_MIGRATION_DIR=
WINLOOP_DB_MIGRATION_FILES=
WINLOOP_DB_MIGRATION_CLIENT_IMAGE=postgres:18-alpine
WINLOOP_DB_MIGRATION_NETWORK=1panel-network

# Runtime env（本批暂不迁移到 UI）
APP_HOST_PORT=3510
WINLOOP_ONLYOFFICE_ENDPOINT=
WINLOOP_ONLYOFFICE_JWT_SECRET=
WINLOOP_PUBLIC_BASE_URL=
# draw.io embed 宿主（留空默认 https://embed.diagrams.net；若使用内网或自托管 draw.io，请填写可访问的绝对地址）
WINLOOP_PUBLIC_DRAWIO_EMBED_BASE_URL=
WINLOOP_TLDRAW_LICENSE_KEY=
WINLOOP_PROJECT_RESOURCE_ACCESS_URL_TTL_SECONDS=600

# Storage
WINLOOP_STORAGE_PROVIDER=local
WINLOOP_STORAGE_LOCAL_ROOT=/app/tmp/document-storage
WINLOOP_STORAGE_ENDPOINT=
WINLOOP_STORAGE_REGION=
WINLOOP_STORAGE_BUCKET=
WINLOOP_STORAGE_ACCESS_KEY=
WINLOOP_STORAGE_SECRET_KEY=
WINLOOP_STORAGE_FORCE_PATH_STYLE=true

# Healthcheck and rollback
WINLOOP_HEALTHCHECK_URL=http://127.0.0.1:3510/api/health
WINLOOP_HEALTHCHECK_ATTEMPTS=20
WINLOOP_HEALTHCHECK_INTERVAL_SEC=3
WINLOOP_ROLLBACK_ON_FAILURE=true
